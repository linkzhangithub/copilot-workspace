{
  "name": "vue3-vite-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "start": "concurrently \"npm run server\" \"npm run dev\" --names \"server,client\" --prefix-colors \"blue,green\"",
    "build": "vite build",
    "preview": "vite preview",
    "prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop copilot-api",
    "pm2:restart": "pm2 restart copilot-api",
    "pm2:logs": "pm2 logs copilot-api",
    "docker:build": "docker build -t copilot-workspace:latest .",
    "docker:run": "docker run -d -p 3000:3000 --env-file .env --name copilot-app copilot-workspace:latest"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "lucide-vue-next": "^1.0.0",
    "sortablejs": "^1.15.7",
    "tencentcloud-serverless-nodejs": "^1.0.3",
    "vue": "^3.4.21",
    "vue-draggable-next": "^2.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0"
  }
}
